{
  "extends": "./tsconfig.base.json",
  "compilerOptions": {
    "lib": ["dom", "esnext", "es6"],
    "paths": {
      "*": ["./*"]
    },
    "moduleResolution": "bundler",
    "module": "ESNext",
    "jsx": "react",
    "types": [
      "vitest/globals",
      "@testing-library/jest-dom",
      "node"
    ]
  },
  "include": ["./src/frontend", "./src/global.d.ts"],
  "exclude": ["./node_modules", "./src/backend"]
}