{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["esnext", "es6"],
    "importHelpers": true, // tslib required
    "declaration": true,
    "sourceMap": true,
    "strict": true,
    "noImplicitAny": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "rootDir": "./src",
    "outDir": "dist"
  },
}